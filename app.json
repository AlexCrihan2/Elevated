{
  "expo": {
    "name": "OnSpace Platform",
    "slug": "onspace-platform",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/logo.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.onspace.platform"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/logo.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.onspace.platform",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.INTERNET",
        "android.permission.VIBRATE",
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT"
      ]
    },
    "web": {
      "favicon": "./assets/images/favicon.ico",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow OnSpace to access your camera to take photos and videos.",
          "microphonePermission": "Allow OnSpace to access your microphone to record audio."
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "Allow OnSpace to access your photos to share and save content.",
          "savePhotosPermission": "Allow OnSpace to save photos to your gallery."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/logo.png",
          "color": "#ffffff",
          "defaultChannel": "default"
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow OnSpace to use your location for weather and local content."
        }
      ],
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Allow OnSpace to use Face ID for secure authentication."
        }
      ],
      "expo-secure-store",
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "scheme": "onspace",
    "extra": {
      "eas": {
        "projectId": "891ec94c-be98-4d25-926a-7509bc52d2b1"
      }
    }
  }
}